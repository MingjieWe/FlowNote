{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "default",
  "rsc": true,
  "registry": [
    {
      "name": "default",
      "item": "components/ui",
      "handler": "https://ui.shadcn.com/r"
    }
  ],
  "theme": "neutral",
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "app/globals.css",
    "baseColor": "neutral",
    "cssVariables": true
  },
  "typescript": true,
  "aliases": {
    "@": "./",
    "@/components": "./components",
    "@/lib": "./lib",
    "@/hooks": "./lib/hooks"
  }
}
